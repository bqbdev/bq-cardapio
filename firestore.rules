rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function businessDoc(estabelecimentoId) {
      return get(/databases/$(database)/documents/estabelecimentos/$(estabelecimentoId));
    }

    function isBusinessOwner(estabelecimentoId) {
      return signedIn()
        && businessDoc(estabelecimentoId).data.uid == request.auth.uid
        && businessDoc(estabelecimentoId).data.status == "ativo";
    }

    function isBusinessUser() {
      return signedIn() && resource.data.uid == request.auth.uid;
    }

    function canActivateBusiness() {
      return signedIn()
        && resource.data.status == "aguardando_ativacao"
        && resource.data.uid == ""
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "ativo"
        && request.resource.data.email == resource.data.email
        && request.resource.data.activationTokenConfirm == resource.data.activationToken;
    }

    match /admins/{adminId} {
      allow read: if isAdmin() || (signedIn() && adminId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /solicitacoes_estabelecimentos/{solicitacaoId} {
      allow create: if solicitacaoId == request.resource.data.emailNormalizado
        && request.resource.data.status == "pendente";
      allow read, update, delete: if isAdmin();
    }

    match /estabelecimentos/{estabelecimentoId} {
      allow read: if isAdmin() || isBusinessUser() || resource.data.status == "ativo";
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || canActivateBusiness();

      match /configuracoes/{configId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /taxas/{taxaId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /categorias/{categoriaId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /produtos/{produtoId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /sabores/{saborId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /adicionais/{adicionalId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /clientes/{clienteId} {
        allow read: if isAdmin() || isBusinessOwner(estabelecimentoId);
        allow create, update: if true;
        allow delete: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /pedidos/{pedidoId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /financeiro/{financeiroId} {
        allow read, write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }
    }

    match /logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
