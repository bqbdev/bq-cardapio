rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function businessDoc(estabelecimentoId) {
      return get(/databases/$(database)/documents/estabelecimentos/$(estabelecimentoId));
    }

    function isBusinessOwner(estabelecimentoId) {
      return signedIn()
        && businessDoc(estabelecimentoId).data.uid == request.auth.uid
        && businessDoc(estabelecimentoId).data.status == "ativo";
    }

    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    match /solicitacoes_estabelecimentos/{solicitacaoId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /estabelecimentos/{estabelecimentoId} {
      allow read: if isAdmin() || isBusinessOwner(estabelecimentoId) || resource.data.status == "ativo";
      allow create, update, delete: if isAdmin();

      match /configuracoes/{configId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /taxas/{taxaId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /categorias/{categoriaId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /produtos/{produtoId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /adicionais/{adicionalId} {
        allow read: if true;
        allow write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /clientes/{clienteId} {
        allow read: if isAdmin() || isBusinessOwner(estabelecimentoId);
        allow create, update: if true;
        allow delete: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /pedidos/{pedidoId} {
        allow read: if isAdmin() || isBusinessOwner(estabelecimentoId);
        allow create: if true;
        allow update, delete: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }

      match /financeiro/{financeiroId} {
        allow read, write: if isAdmin() || isBusinessOwner(estabelecimentoId);
      }
    }

    match /logs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
